APP_NAME="Gandeng Tangan"
APP_ENV=production
APP_KEY=base64:Db+9ddNv2F4bAbO879bvftvRnXW58VaPLBpIz0Y52WU=
APP_DEBUG=true
APP_URL=https://hyperui.s1if.space:8080
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ==========================================
# DATABASE — PostgreSQL
# ==========================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=hyperUI
DB_USERNAME=postgres
DB_PASSWORD=postgres

# ==========================================
# SESSION & CACHE — pakai file (aman tanpa Redis)
# ==========================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=file

# ==========================================
# WHATSAPP
# ==========================================
WHATSAPP_NUMBER=6282163850914
WHATSAPP_DEFAULT_TEXT="Halo admin GandengTangan, saya ingin pesan karya ini:"

# ==========================================
# SCRAPER
# ==========================================
SCRAPER_URL=https://lingkarsosial.org/produk-disabilitas-untuk-ramadhan-dan-lebaran/

# ==========================================
# MAIL (log only, tidak perlu SMTP)
# ==========================================
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@gandengtangan.id"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"